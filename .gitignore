# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets
.env
.env.local
.env.*.local
*.pem
*.key
service-account*.json

# Data — tracked by DVC, not git
data/raw/
data/processed/
data/neo4j/
data/lightrag/
data/orchestrator.db
data/orchestrator.db-*
data/state/

# Results — produced by autonomous agents.
# Ignore everything under results/ EXCEPT the text artifacts we want in git.
# Use results/* (not results/) so children can be re-included via ! negation.
results/*
!results/hermes_outputs/
!results/baselines/
!results/benchmarks/
!results/personas_pilot/
!results/PIPELINE_STATUS.json
# Inside the whitelisted subdirs, ignore large binary artifacts.
results/baselines/*.bin
results/benchmarks/*.bin
results/hermes_outputs/*.bin

# Models — local MLX checkpoints, HF cache
models/
.cache/huggingface/

# Reports build artifacts
reports/build/
reports/sections/*.docx
reports/*.pdf

# OS
.DS_Store
*.swp
*~

# IDE
.vscode/
.idea/

# Logs
*.log
logs/

# DVC internals
.dvc/cache
.dvc/tmp
*.pem
id_*
ku-*

# Cultural training data — regeneratable from build_cultural_dataset.py
data/cultural/*/train.jsonl
data/cultural/*/eval.jsonl
data/wvs/*.csv
