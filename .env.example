# Copy to .env and fill. .env itself is gitignored.

# ---------- Policy gate (set true only after reading COSE461 syllabus) ----------
COURSE_AI_POLICY_VERIFIED=false

# ---------- LLM provider keys ----------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...              # for Gemini judge in panel
# HyperCLOVA / Naver Cloud (optional, ~1 week ETA from Naver to provision)
NAVER_CLOUD_API_KEY=
NAVER_CLOUD_APIGW_KEY=
# Local model server (Qwen3.6-27B-MLX via mlx-server / lm-studio) — base URL
ANSWER_MODEL_BASE_URL=http://localhost:1234/v1
EMBED_MODEL_BASE_URL=http://localhost:11434/v1   # ollama bge-m3
LOCAL_API_KEY=not-needed

# ---------- HuggingFace + DVC ----------
HF_TOKEN=hf_...
DVC_REMOTE_URL=s3://orbt-research-lab-dvc

# ---------- AWS (for QLoRA burst capacity) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-2
AWS_QLORA_INSTANCE_TYPE=g5.2xlarge

# ---------- Neo4j (LightRAG backing store) ----------
NEO4J_PASSWORD=change-me-strong-password

# ---------- Slack (human-in-loop approvals + alerts) ----------
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_RESEARCH=C0123456789      # #orbt-research-lab
SLACK_CHANNEL_ALERTS=C0123456789        # severity >= red goes here

# ---------- Orchestrator ----------
ORCHESTRATOR_DB=./data/orchestrator.db
ORCHESTRATOR_TICK_SECONDS=60
QA_META_TICK_SECONDS=3600
PI_TICK_SECONDS=86400

# ---------- Budget caps (USD) — guard kills if breached ----------
DAILY_BUDGET_LIMIT=30
WEEKLY_BUDGET_LIMIT=120
TOTAL_BUDGET_LIMIT=400
EMERGENCY_STOP_THRESHOLD=0.90
